{
  "manifest_version": 3,
  "name": "MailGuard Pro",
  "version": "7.0.0",
  "description": "AI-powered email threat intelligence. Phishing, malicious URLs, prompt injection — all detected locally with your own ML models.",
  "permissions": ["identity","storage","alarms","scripting","notifications","tabs"],
  "host_permissions": [
    "https://gmail.googleapis.com/*",
    "https://www.googleapis.com/*",
    "https://api.openai.com/*",
    "https://mail.google.com/*",
    "http://localhost:5000/*"
  ],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "16":"icons/icon16.png","48":"icons/icon48.png","128":"icons/icon128.png" },
    "default_badge_color": "#F43F5E"
  },
  "content_scripts": [{
    "matches": ["https://mail.google.com/*"],
    "js": ["content.js"],
    "css": ["content.css"],
    "run_at": "document_idle"
  }],
  "oauth2": {
    "client_id": "1097868957703-0ppkpbln50fqmdqmi1390l2ai469ffgk.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly",
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  },
  "web_accessible_resources": [{ "resources": ["dashboard.html","home.html","home.js"], "matches": ["<all_urls>"] }],
  "icons": { "16":"icons/icon16.png","48":"icons/icon48.png","128":"icons/icon128.png" },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; connect-src http://localhost:5000 https://api.openai.com https://gmail.googleapis.com https://www.googleapis.com;"
  }
}
